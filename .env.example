# PRISM configuration — copy to .env and adjust

# Server
PRISM_HOST=0.0.0.0
PRISM_PORT=3000
PRISM_DEBUG=false

# MITM Proxy
PRISM_MITM_HOST=127.0.0.1
PRISM_MITM_PORT=8080

# Storage
PRISM_DB_PATH=/data/prism.db
# Or use PostgreSQL:
# PRISM_DB_URL=postgresql+asyncpg://user:pass@localhost/prism

PRISM_DATA_DIR=/data
PRISM_CERTS_DIR=/data/certs
PRISM_SCRIPTS_DIR=/scripts
PRISM_UPLOADS_DIR=/data/uploads

# TLS key logging (for Wireshark decryption verification)
SSLKEYLOGFILE=/data/sslkeys.log

# Security
PRISM_REDACT_SECRETS=true
PRISM_DATA_RETENTION_DAYS=30
